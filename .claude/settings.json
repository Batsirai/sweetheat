{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": ".claude/hooks/enzyme-petri.sh",
            "type": "command"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "mempalace": {
      "args": [
        "-m",
        "mempalace.mcp_server"
      ],
      "command": "/usr/local/bin/python3.11"
    },
    "sweet-heat": {
      "args": [
        "/Users/batsirai/SweetContent/mcp-server/index.js"
      ],
      "command": "node",
      "env": {
        "SLACK_WEBHOOK_URL": "${SLACK_WEBHOOK_URL}",
        "SWEET_HEAT_API_KEY": "${SWEET_HEAT_API_KEY}",
        "SWEET_HEAT_URL": "http://localhost:5173"
      }
    }
  }
}